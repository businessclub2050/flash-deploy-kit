# =============================================================================
# Sovereign AI Node — Configuration
# =============================================================================
#
# Copy this file to sovereign-node.env and edit for your deployment.
#
# USAGE (Proxmox — zero-touch, cloud-init):
#   cp sovereign-node.env.example sovereign-node.env
#   vi sovereign-node.env
#   ./create-node.sh sovereign-node.env   # Creates VM + provisions everything
#
# USAGE (Bare-metal / existing VM — manual):
#   cp sovereign-node.env.example sovereign-node.env
#   vi sovereign-node.env
#   ./install.sh sovereign-node.env       # Provisions the current machine
#
# Uses Debian 13 "Trixie" Generic Cloud Image (cloud-init enabled).
# The generic qcow2 is hypervisor-agnostic: Proxmox, ESXi, raw KVM.
# Kernel 6.12+ with native multi-GPU memory management for Tesla T4/L4/A100.
#
# The installer reads this file and provisions the full stack:
#   Ollama (LLM) + Open WebUI (chat) + ComfyUI (images) + OpenClaw (agents)
#   + Tailscale (private access) + Cloudflare (public access, optional)
#
# =============================================================================

# --- Deployment Identity ---
CUSTOMER_NAME="My AI Node"
NODE_HOSTNAME="sovereign-node"

# --- Proxmox VM Settings (used by create-node.sh) ---
# Only needed when using create-node.sh on a Proxmox host.
# Ignored by install.sh on bare-metal / existing VMs.
VM_ID="501"
VM_CORES="8"
VM_SOCKETS="1"
VM_MEMORY="65536"
VM_DISK_SIZE="92G"
VM_STORAGE="data"
VM_BRIDGE="vmbr0"
# Auto-start: "order=1" or "order=2,up=30" (empty = no auto-start)
VM_STARTUP_ORDER="order=1"
VM_ONBOOT="1"
# Root password for cloud-init (default: configured during install — SSH key auth recommended)
ROOT_PASSWORD=" "
# GPU PCI addresses for passthrough (comma-separated, empty = no GPU passthrough)
# Find addresses: lspci | grep -i nvidia
# Example (2x Tesla T4): "05:00.0,0b:00.0"
GPU_PASSTHROUGH=""

# --- Platform ---
# Options: proxmox | vmware | docker | baremetal | cloud
PLATFORM="baremetal"

# --- Network ---
# Set to "dhcp" for automatic, or provide static values
NETWORK_MODE="static"
IP_ADDRESS="10.42.0.150"
GATEWAY="10.42.0.1"
DNS="10.42.0.1"
# Leave blank for auto-detection (recommended)
NIC_INTERFACE=""

# --- GPU ---
# "auto" = detect via nvidia-smi and pick best model for available VRAM
# Or specify: 0, 1, 2, etc. for GPU count override
GPU_COUNT="auto"

# --- Model ---
# "auto" = select based on available VRAM:
#   ≤8GB  → qwen2.5:7b
#   ≤16GB → qwen2.5:14b
#   ≤48GB → qwen2.5:32b
#   >48GB → qwen2.5:72b (or deepseek-v3 if available)
# Or specify any Ollama model name (e.g., "llama3:8b", "deepseek-v3:32b")
MODEL_NAME="auto"

# --- Ports ---
OLLAMA_PORT="11434"
WEBUI_PORT="3000"
COMFYUI_PORT="8188"
OPENCLAW_PORT="18789"

# --- GPU Pinning (optional) ---
# Which GPU(s) for Ollama (LLM inference). Default: GPU 0
OLLAMA_CUDA_DEVICES="0"
# Which GPU(s) for ComfyUI (image generation). Default: GPU 1 (if available)
COMFYUI_CUDA_DEVICES="1"

# --- License ---
# Tier: starter | professional | business | enterprise
LICENSE_TIER="starter"
LICENSE_KEY=""

# License enforcement:
#   starter:      5 seats, models ≤14B, 1 agent persona
#   professional: 15 seats, models ≤32B, 5 agent personas, 5GB/mo scraping
#   business:     50 seats, models ≤70B, 15 agent personas, 50GB/mo scraping
#   enterprise:   unlimited
MAX_SEATS="5"
MAX_AGENTS="1"

# --- Web Research / Scraping (paid add-on) ---
SCRAPE_ENABLED="false"
# Proxy endpoint for rotating residential proxies (managed add-on)
# Format: http://user:pass@gate.provider.com:7777
PROXY_ENDPOINT=""

# --- Tailscale (private access) ---
# Pre-auth key for automatic Tailscale join (optional)
# Generate at: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=""

# --- Cloudflare Tunnel (public access, optional) ---
CLOUDFLARE_ENABLED="false"
CLOUDFLARE_TUNNEL_TOKEN=""
CLOUDFLARE_DOMAIN=""

# --- SSH Keys ---
# SSH public keys to authorize for root access.
# One key per line, wrapped in quotes. These get injected via cloud-init
# AND written to /root/.ssh/authorized_keys by install.sh.
SSH_AUTHORIZED_KEYS="
"

# --- ComfyUI ---
# Enable image generation (requires GPU with ≥12GB VRAM on COMFYUI_CUDA_DEVICES)
COMFYUI_ENABLED="true"
# Hugging Face token for downloading gated models (FLUX.1, etc.)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=""

# --- Docker ---
# Where Docker stores container data (default: /var/lib/docker)
# Set to a larger partition if root disk is small
DOCKER_DATA_ROOT="/var/lib/docker"

# --- Advanced ---
# Set to "true" to skip interactive confirmations
NON_INTERACTIVE="false"
# Set to "true" to enable verbose logging
DEBUG="false"
